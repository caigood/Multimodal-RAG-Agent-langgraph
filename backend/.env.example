# ==================== 阿里云凭据（OSS 用）====================
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=

# ==================== LLM 配置 ====================
DASHSCOPE_API_KEY=
LLM_MODEL=qwen3.7-plus
LLM_CLEAN_MODEL=deepseek-v4-flash
KG_EXTRACT_MODEL=deepseek-v4-flash
LANGSMITH_TRACING=

# ==================== Milvus 向量数据库 ====================
MILVUS_HOST=
MILVUS_PORT=
MILVUS_USER=
MILVUS_PASSWORD=
# ==================== PostgreSQL 业务数据库 ====================
PG_HOST=
PG_PORT=
PG_DB=
PG_USER=
PG_PASSWORD=

# ==================== Neo4j 知识图谱 ====================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password
NEO4J_DATABASE=neo4j

# ==================== Embedding 配置 ====================
# 调用 DashScope 生成向量，需要 DASHSCOPE_API_KEY
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIMENSION=1536
# 每批最多发送的文本数量（DashScope 单次最多 25 条）
EMBEDDING_BATCH_SIZE=20

# ==================== 向量检索配置 ====================
VECTOR_TOP_K=10
VECTOR_SCORE_THRESHOLD=0

# ==================== 切片配置 ====================
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ==================== MinIO 配置（docker-compose 用）====================
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ==================== PostgreSQL 配置（docker-compose 用）====================
POSTGRES_DB=knowledge_db
POSTGRES_USER=kbuser
POSTGRES_PASSWORD=kbpass

# ==================== OSS 配置 ====================
OSS_BUCKET=
OSS_REGION=cn-shanghai
OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com

# ==================== API 配置 ====================
API_HOST=0.0.0.0
API_PORT=8000
SSL_VERIFY=false

# ==================== Tavily 搜索配置 ====================
# 前往 https://tavily.com 注册获取 API Key（每月 1000 次免费调用）
TAVILY_API_KEY=
TAVILY_API_URL=https://api.tavily.com/search

# ==================== SMTP 邮件发送配置 ====================
# 系统统一发件邮箱配置；QQ/163 等邮箱请填写 SMTP 授权码，不要填写网页登录密码
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=RAG知识库助手
SMTP_USE_SSL=true
